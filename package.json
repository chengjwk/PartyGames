{
  "name": "wordhive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,party -c blue,magenta \"npm:dev:web\" \"npm:dev:party\"",
    "dev:web": "vite",
    "dev:party": "partykit dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy:party": "partykit deploy",
    "deploy:web": "vite build && wrangler pages deploy dist --project-name wordhive",
    "deploy": "npm run deploy:party && npm run deploy:web"
  },
  "dependencies": {
    "partysocket": "^1.0.2",
    "qrcode.react": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "partykit": "^0.0.114",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wrangler": "^3.86.1"
  }
}
